<Window x:Class="CadZapatas.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CadZapatas.Desktop.ViewModels"
        xmlns:h="http://helix-toolkit.org/wpf"
        Title="CadZapatas - CAD/BIM de cimentaciones (CTE DB-SE-C + Codigo Estructural)"
        Height="800" Width="1280"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <DockPanel>
        <!-- Toolbar superior -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Content="Nuevo"        Command="{Binding NewProjectCommand}"/>
                <Button Content="Abrir..."     Command="{Binding OpenProjectCommand}"/>
                <Button Content="Guardar como..." Command="{Binding SaveAsCommand}"/>
                <Separator/>
                <Button Content="+ Zapata"     Command="{Binding AddFootingCommand}"/>
                <Button Content="+ Muro"       Command="{Binding AddWallCommand}"/>
                <Separator/>
                <Button Content="Comprobar TODO" Command="{Binding RunAllChecksCommand}"
                        Background="#2563EB" Foreground="White" FontWeight="Bold"/>
                <Separator/>
                <Button Content="Memoria PDF"  Command="{Binding ExportPdfCommand}"/>
                <Button Content="Mediciones BC3" Command="{Binding ExportBc3Command}"/>
            </ToolBar>
        </ToolBarTray>

        <!-- Barra de estado inferior -->
        <StatusBar DockPanel.Dock="Bottom" Background="#E5E7EB">
            <StatusBarItem Content="{Binding StatusText}"/>
            <Separator/>
            <StatusBarItem Content="{Binding Project.Name}"/>
            <Separator/>
            <StatusBarItem Content="{Binding Project.GeotechnicalNormCode}"/>
            <Separator/>
            <StatusBarItem Content="{Binding Project.StructuralNormCode}"/>
        </StatusBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>      <!-- Navegador -->
                <ColumnDefinition Width="*"/>        <!-- Viewport 3D -->
                <ColumnDefinition Width="380"/>      <!-- Incidencias -->
            </Grid.ColumnDefinitions>

            <!-- Navegador de proyecto -->
            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" Padding="8">
                <StackPanel>
                    <TextBlock Text="PROYECTO" FontWeight="Bold" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding Project.Name}" TextWrapping="Wrap" FontSize="13"/>

                    <Separator Margin="0,8"/>
                    <Expander Header="Cimentaciones" IsExpanded="True">
                        <ItemsControl ItemsSource="{Binding Footings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="8,2">
                                        <Run Text="{Binding Code}"/>
                                        <Run Text=" - "/>
                                        <Run Text="{Binding Length}"/>x<Run Text="{Binding Width}"/>x<Run Text="{Binding Thickness}"/> m
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>

                    <Expander Header="Muros de contencion" IsExpanded="True">
                        <ItemsControl ItemsSource="{Binding Walls}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="8,2">
                                        <Run Text="{Binding Code}"/>
                                        <Run Text=" - H="/>
                                        <Run Text="{Binding Height}"/> m
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>

                    <Expander Header="Modelo de suelo">
                        <ItemsControl ItemsSource="{Binding SoilModel.Layers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="8,2" Text="{Binding Name}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>
                </StackPanel>
            </Border>

            <!-- Viewport 3D -->
            <h:HelixViewport3D Grid.Column="1" x:Name="Viewport"
                               ShowCoordinateSystem="True" ShowFrameRate="False"
                               Background="#FAFAFA"
                               ZoomExtentsWhenLoaded="True">
                <h:SunLight/>
                <h:GridLinesVisual3D Fill="#CCC" MajorDistance="1" MinorDistance="0.2"
                                     Width="20" Length="20"/>
            </h:HelixViewport3D>

            <!-- Panel de incidencias (lista de CalcTrace) -->
            <Border Grid.Column="2" Background="{StaticResource PanelBrush}" Padding="8">
                <DockPanel>
                    <TextBlock Text="COMPROBACIONES NORMATIVAS" DockPanel.Dock="Top"
                               FontWeight="Bold" Margin="0,0,0,6"/>
                    <DataGrid ItemsSource="{Binding Traces}" AutoGenerateColumns="False"
                              IsReadOnly="True" HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal" RowHeight="22"
                              AlternatingRowBackground="#F9FAFB">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Elemento" Binding="{Binding ElementType}" Width="*"/>
                            <DataGridTextColumn Header="Chequeo"  Binding="{Binding CheckName}"   Width="*"/>
                            <DataGridTextColumn Header="η"        Binding="{Binding Utilization, StringFormat=F2}" Width="50"/>
                            <DataGridTextColumn Header="Veredicto" Binding="{Binding Verdict}"    Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
